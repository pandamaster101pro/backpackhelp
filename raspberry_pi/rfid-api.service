[Unit]
Description=Backpack RFID API
After=network-online.target tailscaled.service
Wants=network-online.target tailscaled.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/backpack-rfid
Environment=RFID_PORT=8000
EnvironmentFile=-/etc/backpack-rfid.env
ExecStart=/home/pi/backpack-rfid/.venv/bin/python /home/pi/backpack-rfid/rfid_api.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
